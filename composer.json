{
    "name": "sarkhanrasimoghlu/laravel-kapital-bank-payment",
    "description": "Laravel package for Kapital Bank Merchant API V1.3 payment integration",
    "keywords": [
        "kapital-bank",
        "payment",
        "laravel",
        "merchant",
        "api",
        "php",
        "azerbaijan"
    ],
    "homepage": "https://github.com/Rasimoghlu/laravel-kapital-bank-payment",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Sarkhanrasimoghlu\\KapitalBank\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sarkhanrasimoghlu\\KapitalBank\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Sarkhan Rasimoghlu",
            "email": "nasibovsarxan92@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.0",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.9"
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "test-unit": "phpunit --testsuite=Unit",
        "test-feature": "phpunit --testsuite=Feature",
        "test-filter": "phpunit --filter",
        "analyse": "phpstan analyse src --level=8",
        "check-style": "phpcs",
        "fix-style": "phpcbf"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sarkhanrasimoghlu\\KapitalBank\\KapitalBankServiceProvider"
            ]
        }
    }
}
