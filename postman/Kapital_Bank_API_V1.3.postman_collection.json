{
	"info": {
		"name": "Kapital Bank API V1.3",
		"description": "Kapital Bank Checkout Merchant API V1.3 — Laravel package endpoint-lərinin test collection-u.\n\n## Başlamaq üçün:\n1. Environment-i import edin\n2. `base_url`, `client_id`, `client_secret` dəyərlərini doldurun\n3. İlk öncə **1. Get OAuth2 Token** göndərin — token avtomatik saxlanılacaq\n4. Sonra digər endpoint-ləri test edin",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{access_token}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Auto-refresh token if expired",
					"const tokenExpiry = pm.environment.get('token_expiry');",
					"if (tokenExpiry && Date.now() < parseInt(tokenExpiry)) {",
					"    return;",
					"}",
					"",
					"// Skip auto-refresh for the token endpoint itself",
					"if (pm.info.requestName === '1. Get OAuth2 Token') {",
					"    return;",
					"}",
					"",
					"const clientId = pm.environment.get('client_id');",
					"const clientSecret = pm.environment.get('client_secret');",
					"const baseUrl = pm.environment.get('base_url');",
					"",
					"if (!clientId || !clientSecret || !baseUrl) {",
					"    console.warn('Missing credentials — skipping auto-refresh');",
					"    return;",
					"}",
					"",
					"pm.sendRequest({",
					"    url: baseUrl + '/oauth2/token',",
					"    method: 'POST',",
					"    header: {",
					"        'Content-Type': 'application/x-www-form-urlencoded',",
					"        'Accept': 'application/json'",
					"    },",
					"    body: {",
					"        mode: 'urlencoded',",
					"        urlencoded: [",
					"            { key: 'grant_type', value: 'client_credentials' },",
					"            { key: 'client_id', value: clientId },",
					"            { key: 'client_secret', value: clientSecret }",
					"        ]",
					"    }",
					"}, function (err, res) {",
					"    if (err) {",
					"        console.error('Token refresh failed:', err);",
					"        return;",
					"    }",
					"    const json = res.json();",
					"    if (json.access_token) {",
					"        pm.environment.set('access_token', json.access_token);",
					"        pm.environment.set('token_expiry', Date.now() + ((json.expires_in || 3500) * 1000));",
					"        console.log('Token auto-refreshed');",
					"    }",
					"});"
				]
			}
		}
	],
	"variable": [
		{
			"key": "payment_id",
			"value": ""
		},
		{
			"key": "refund_id",
			"value": ""
		}
	],
	"item": [
		{
			"name": "Auth",
			"description": "OAuth2 authentication",
			"item": [
				{
					"name": "1. Get OAuth2 Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has access_token', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('access_token');",
									"    pm.expect(json.access_token).to.be.a('string').and.not.empty;",
									"});",
									"",
									"// Save token to environment",
									"const json = pm.response.json();",
									"if (json.access_token) {",
									"    pm.environment.set('access_token', json.access_token);",
									"    const expiresIn = json.expires_in || 3500;",
									"    pm.environment.set('token_expiry', Date.now() + (expiresIn * 1000));",
									"    console.log('Token saved, expires in ' + expiresIn + 's');",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "grant_type",
									"value": "client_credentials"
								},
								{
									"key": "client_id",
									"value": "{{client_id}}"
								},
								{
									"key": "client_secret",
									"value": "{{client_secret}}"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/oauth2/token",
							"host": ["{{base_url}}"],
							"path": ["oauth2", "token"]
						},
						"description": "OAuth2 client_credentials grant ilə Bearer token almaq.\n\nToken avtomatik olaraq environment-ə saxlanılır və digər request-lərdə istifadə olunur."
					}
				}
			]
		},
		{
			"name": "Payments",
			"description": "Payment CRUD əməliyyatları",
			"item": [
				{
					"name": "2. Create Payment",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200 or 201', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
									"});",
									"",
									"pm.test('Response has id and redirect_url', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('id');",
									"    pm.expect(json).to.have.property('redirect_url');",
									"});",
									"",
									"// Save payment_id for subsequent requests",
									"const json = pm.response.json();",
									"if (json.id) {",
									"    pm.collectionVariables.set('payment_id', json.id);",
									"    pm.environment.set('payment_id', json.id);",
									"    console.log('Payment ID saved: ' + json.id);",
									"}",
									"if (json.redirect_url) {",
									"    pm.environment.set('payment_redirect_url', json.redirect_url);",
									"    console.log('Redirect URL: ' + json.redirect_url);",
									"}"
								]
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Generate unique order ID",
									"const orderId = 'ORDER-' + Date.now();",
									"pm.variables.set('generated_order_id', orderId);",
									"",
									"// Generate idempotency key",
									"const idempotencyKey = pm.variables.replaceIn('{{$guid}}');",
									"pm.variables.set('idempotency_key', idempotencyKey);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "X-Idempotency-Key",
								"value": "{{idempotency_key}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"terminal_id\": \"{{terminal_id}}\",\n    \"amount\": 10.00,\n    \"currency\": \"AZN\",\n    \"order_id\": \"{{generated_order_id}}\",\n    \"description\": \"Test payment from Postman\",\n    \"language\": \"az\",\n    \"success_url\": \"{{success_url}}\",\n    \"error_url\": \"{{error_url}}\",\n    \"callback_url\": \"{{callback_url}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/payments",
							"host": ["{{base_url}}"],
							"path": ["v1", "payments"]
						},
						"description": "Yeni payment yaratmaq.\n\nUğurlu cavabda `id` və `redirect_url` qaytarılır. `redirect_url` müştərini ödəniş səhifəsinə yönləndirir.\n\n`payment_id` avtomatik saxlanılır."
					}
				},
				{
					"name": "3. Get Payment Status",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has status field', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('status');",
									"});",
									"",
									"pm.test('Status is valid enum value', function () {",
									"    const json = pm.response.json();",
									"    const validStatuses = ['pending', 'succeeded', 'canceled', 'waiting_for_capture', 'refunded', 'partially_refunded'];",
									"    pm.expect(validStatuses).to.include(json.status);",
									"});",
									"",
									"const json = pm.response.json();",
									"console.log('Payment status: ' + json.status);",
									"if (json.payment_method) {",
									"    console.log('Payment method: ' + json.payment_method);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/v1/payments/{{payment_id}}",
							"host": ["{{base_url}}"],
							"path": ["v1", "payments", "{{payment_id}}"]
						},
						"description": "Payment-in cari statusunu almaq.\n\n**GET** method istifadə olunur (köhnə API-dən fərqli olaraq POST yox).\n\nMümkün status-lar: `pending`, `succeeded`, `canceled`, `waiting_for_capture`"
					}
				},
				{
					"name": "4. Cancel Payment",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Payment is canceled', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('status');",
									"    pm.expect(json.status).to.equal('canceled');",
									"});",
									"",
									"console.log('Payment canceled successfully');"
								]
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const idempotencyKey = pm.variables.replaceIn('{{$guid}}');",
									"pm.variables.set('idempotency_key', idempotencyKey);"
								]
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "X-Idempotency-Key",
								"value": "{{idempotency_key}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"cancellation_reason\": \"canceled_by_merchant\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/payments/{{payment_id}}/cancel",
							"host": ["{{base_url}}"],
							"path": ["v1", "payments", "{{payment_id}}", "cancel"]
						},
						"description": "Payment-i ləğv etmək.\n\n**PUT** method istifadə olunur.\n\nMümkün `cancellation_reason` dəyərləri:\n- `canceled_by_merchant`\n- `canceled_by_payment_network`\n- `expired_on_confirmation`\n- `insufficient_funds`\n- `three_ds_verification_failed`\n- `expired_on_capture`\n- `issuer_decline`\n- `general_decline`"
					}
				}
			]
		},
