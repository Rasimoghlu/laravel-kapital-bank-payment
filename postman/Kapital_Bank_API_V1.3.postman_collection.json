		{
			"name": "Webhook (Test)",
			"item": [
				{
					"name": "7a. Simulate Webhook — payment_succeeded",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});"
								]
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const body = pm.variables.replaceIn(pm.request.body.raw);",
									"const secretKey = pm.environment.get('secret_key');",
									"if (secretKey) {",
									"    const signature = CryptoJS.HmacSHA256(body, secretKey);",
									"    pm.variables.set('webhook_signature', CryptoJS.enc.Base64.stringify(signature));",
									"} else {",
									"    pm.variables.set('webhook_signature', '');",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Signature",
								"value": "{{webhook_signature}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"event\": \"payment_succeeded\",\n    \"payload\": {\n        \"id\": \"{{payment_id}}\",\n        \"type\": \"payment\",\n        \"status\": \"succeeded\",\n        \"paymentMethod\": \"card\"\n    }\n}"
						},
						"url": {
							"raw": "{{app_url}}/kapital-bank/callback",
							"host": ["{{app_url}}"],
							"path": ["kapital-bank", "callback"]
						}
					}
				},
				{
					"name": "7b. Simulate Webhook — payment_canceled",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});"
								]
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const body = pm.variables.replaceIn(pm.request.body.raw);",
									"const secretKey = pm.environment.get('secret_key');",
									"if (secretKey) {",
									"    const signature = CryptoJS.HmacSHA256(body, secretKey);",
									"    pm.variables.set('webhook_signature', CryptoJS.enc.Base64.stringify(signature));",
									"} else {",
									"    pm.variables.set('webhook_signature', '');",
									"}"
								]
							}
						}
