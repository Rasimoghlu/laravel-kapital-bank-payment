		{
			"name": "Webhook (Test)",
			"description": "Webhook callback simulyasiyası — Laravel app-in callback endpoint-ini test etmək üçün",
			"item": [
				{
					"name": "7a. Simulate Webhook — payment_succeeded",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response is ok', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.status).to.equal('ok');",
									"});"
								]
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Generate HMAC-SHA256 Base64 signature from raw body",
									"const body = pm.variables.replaceIn(pm.request.body.raw);",
									"const secretKey = pm.environment.get('secret_key');",
									"",
									"if (secretKey) {",
									"    const signature = CryptoJS.HmacSHA256(body, secretKey);",
									"    const base64Sig = CryptoJS.enc.Base64.stringify(signature);",
									"    pm.variables.set('webhook_signature', base64Sig);",
									"    console.log('Generated X-Signature: ' + base64Sig);",
									"} else {",
									"    console.warn('secret_key not set — X-Signature will be empty');",
									"    pm.variables.set('webhook_signature', '');",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "X-Signature",
								"value": "{{webhook_signature}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"event\": \"payment_succeeded\",\n    \"payload\": {\n        \"id\": \"{{payment_id}}\",\n        \"type\": \"payment\",\n        \"status\": \"succeeded\",\n        \"paymentMethod\": \"card\"\n    }\n}"
						},
						"url": {
							"raw": "{{app_url}}/kapital-bank/callback",
							"host": ["{{app_url}}"],
							"path": ["kapital-bank", "callback"]
						},
						"description": "Laravel app-ə `payment_succeeded` webhook göndərmək.\n\n**Qeyd:** Bu request Kapital Bank API-nə yox, sizin Laravel app-ə gedir.\n\n`X-Signature` pre-request script-də avtomatik generate olunur (`secret_key` lazımdır)."
					}
				},
				{
					"name": "7b. Simulate Webhook — payment_canceled",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response is ok', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.status).to.equal('ok');",
									"});"
								]
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const body = pm.variables.replaceIn(pm.request.body.raw);",
									"const secretKey = pm.environment.get('secret_key');",
									"",
									"if (secretKey) {",
									"    const signature = CryptoJS.HmacSHA256(body, secretKey);",
									"    const base64Sig = CryptoJS.enc.Base64.stringify(signature);",
									"    pm.variables.set('webhook_signature', base64Sig);",
									"} else {",
									"    pm.variables.set('webhook_signature', '');",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "X-Signature",
								"value": "{{webhook_signature}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"event\": \"payment_canceled\",\n    \"payload\": {\n        \"id\": \"{{payment_id}}\",\n        \"type\": \"payment\",\n        \"status\": \"canceled\",\n        \"paymentMethod\": \"card\"\n    }\n}"
						},
						"url": {
							"raw": "{{app_url}}/kapital-bank/callback",
							"host": ["{{app_url}}"],
							"path": ["kapital-bank", "callback"]
						},
						"description": "Laravel app-ə `payment_canceled` webhook göndərmək."
					}
				}
			]
		}
	]
}
