{
	"info": {
		"name": "Kapital Bank API V1.3",
		"description": "Kapital Bank Checkout Merchant API V1.3\n\n## Başlamaq üçün:\n1. Environment-i import edin\n2. `base_url`, `client_id`, `client_secret`, `merchant_id`, `terminal_id` dəyərlərini doldurun\n3. İlk öncə **1. Get OAuth2 Token** göndərin — token avtomatik saxlanılacaq\n4. Sonra digər endpoint-ləri test edin",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{access_token}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Auto-refresh token if expired",
					"const tokenExpiry = pm.environment.get('token_expiry');",
					"if (tokenExpiry && Date.now() < parseInt(tokenExpiry)) {",
					"    return;",
					"}",
					"",
					"if (pm.info.requestName === '1. Get OAuth2 Token') {",
					"    return;",
					"}",
					"",
					"const clientId = pm.environment.get('client_id');",
					"const clientSecret = pm.environment.get('client_secret');",
					"const baseUrl = pm.environment.get('base_url');",
					"",
					"if (!clientId || !clientSecret || !baseUrl) {",
					"    console.warn('Missing credentials — skipping auto-refresh');",
					"    return;",
					"}",
					"",
					"pm.sendRequest({",
					"    url: baseUrl + '/api/oauth2/token',",
					"    method: 'POST',",
					"    header: {",
					"        'Content-Type': 'application/x-www-form-urlencoded'",
					"    },",
					"    body: {",
					"        mode: 'urlencoded',",
					"        urlencoded: [",
					"            { key: 'grant_type', value: 'client_credentials' },",
					"            { key: 'scope', value: 'email' },",
					"            { key: 'client_id', value: clientId },",
					"            { key: 'client_secret', value: clientSecret }",
					"        ]",
					"    }",
					"}, function (err, res) {",
					"    if (err) {",
					"        console.error('Token refresh failed:', err);",
					"        return;",
					"    }",
					"    const json = res.json();",
					"    if (json.accessToken) {",
					"        pm.environment.set('access_token', json.accessToken);",
					"        pm.environment.set('token_expiry', Date.now() + ((json.accessExpiresIn || 500) * 1000));",
					"        console.log('Token auto-refreshed');",
					"    }",
					"});"
				]
			}
		}
	],
	"variable": [
		{
			"key": "payment_id",
			"value": ""
		},
		{
			"key": "refund_id",
			"value": ""
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "1. Get OAuth2 Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has accessToken', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('accessToken');",
									"});",
									"",
									"const json = pm.response.json();",
									"if (json.accessToken) {",
									"    pm.environment.set('access_token', json.accessToken);",
									"    const expiresIn = json.accessExpiresIn || 500;",
									"    pm.environment.set('token_expiry', Date.now() + (expiresIn * 1000));",
									"    console.log('Token saved, expires in ' + expiresIn + 's');",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "grant_type",
									"value": "client_credentials"
								},
								{
									"key": "scope",
									"value": "email"
								},
								{
									"key": "client_id",
									"value": "{{client_id}}"
								},
								{
									"key": "client_secret",
									"value": "{{client_secret}}"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/api/oauth2/token",
							"host": ["{{base_url}}"],
							"path": ["api", "oauth2", "token"]
						}
					}
				}
			]
		},
		{
			"name": "Payments",
			"item": [
				{
					"name": "2. Create Payment",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has id and confirmation', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('id');",
									"    pm.expect(json).to.have.property('confirmation');",
									"});",
									"",
									"const json = pm.response.json();",
									"if (json.id) {",
									"    pm.collectionVariables.set('payment_id', json.id);",
									"    pm.environment.set('payment_id', json.id);",
									"    console.log('Payment ID saved: ' + json.id);",
									"}",
									"if (json.confirmation) {",
									"    const url = json.confirmation.url || json.confirmation.confirmUrl || json.confirmation.confirmData || '';",
									"    console.log('Confirmation type: ' + json.confirmation.type);",
									"    console.log('Confirmation URL: ' + url);",
									"}"
								]
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const orderId = 'ORDER-' + Date.now();",
									"pm.variables.set('generated_order_id', orderId);",
									"pm.variables.set('idempotency_key', pm.variables.replaceIn('{{$guid}}'));"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Idempotency-Key",
								"value": "{{idempotency_key}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"amount\": {\n        \"value\": 10.0,\n        \"currency\": \"AZN\"\n    },\n    \"capture\": true,\n    \"description\": \"Test payment from Postman\",\n    \"paymentMethodData\": {\n        \"type\": \"BANK_CARD\"\n    },\n    \"confirmation\": {\n        \"type\": \"REDIRECT\",\n        \"returnUrl\": \"{{return_url}}\"\n    },\n    \"posDetail\": {\n        \"merchantId\": \"{{merchant_id}}\",\n        \"terminalId\": \"{{terminal_id}}\"\n    },\n    \"metadata\": {\n        \"orderNo\": \"{{generated_order_id}}\"\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/payments",
							"host": ["{{base_url}}"],
							"path": ["v1", "payments"]
						}
					}
				},
				{
					"name": "3. Get Payment Status",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has id and status', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('id');",
									"    pm.expect(json).to.have.property('status');",
									"});",
									"",
									"const json = pm.response.json();",
									"console.log('Status: ' + json.status);",
									"console.log('Paid: ' + json.paid);",
									"console.log('Captured: ' + json.captured);"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/v1/payments/{{payment_id}}",
							"host": ["{{base_url}}"],
							"path": ["v1", "payments", "{{payment_id}}"]
						}
					}
				},
				{
					"name": "4. Cancel Payment",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Payment is canceled', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.status).to.equal('canceled');",
									"});",
									"",
									"console.log('Payment canceled successfully');"
								]
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [],
						"url": {
							"raw": "{{base_url}}/v1/payments/{{payment_id}}/cancel",
							"host": ["{{base_url}}"],
							"path": ["v1", "payments", "{{payment_id}}", "cancel"]
						}
					}
				}
			]
		},
